rules_version = '2';

// ============================================================
// Ikhlas — Storage Security Rules
// LAW 3 (photos): originals are NEVER publicly readable.
// A user may upload/replace their own photos; reads happen only through
// a backend signed-URL + watermark function (Phase 2). No public reads.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // users/{uid}/photos/* — private profile photos
    match /users/{uid}/photos/{fileName} {
      // Upload/replace/delete: only the owner.
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024          // 8MB cap
                   && request.resource.contentType.matches('image/.*'); // images only

      // Owner sees their own photos (profile builder); moderators for
      // review. OTHER members never read directly — cross-user viewing
      // ships in Phase 2 exclusively via signed URLs + watermarking.
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.token.moderator == true);
    }

    // Selfie-verification captures — owner writes; only moderators read
    // (the admin review queue shows the selfie; members never see it).
    match /users/{uid}/verification/{fileName} {
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read: if request.auth != null
                  && request.auth.token.moderator == true;
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
